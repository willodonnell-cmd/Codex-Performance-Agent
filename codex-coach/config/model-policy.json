      "recommendedModel": "gpt-5.4-mini",
      "recommendedReasoning": "low",
      "displayName": "GPT-5.4-mini (Low)"
    },
    "standard": {
      "label": "Standard",
      "defaultUse": ["planning", "implementation", "ordinary debugging", "review"],
      "recommendedModel": "gpt-5.5",
      "recommendedReasoning": "low",
      "displayName": "GPT-5.5 (Low)"
    },
    "premium": {
      "label": "Premium",
      "defaultUse": ["architecture", "hard debugging", "ambiguous reasoning", "multi-step orchestration"],
      "recommendedModel": "gpt-5.5",
      "recommendedReasoning": "high",
      "displayName": "GPT-5.5 (High)"
    }
  },
  "routingRules": [
    {
      "task": "research",
      "defaultModelClass": "standard",
      "escalateWhen": "Source conflict, high-stakes synthesis, or ambiguous decision framing."
