{
  "weeklyAllocationCredits": 2650,
  "budgetPressure": [
    {
      "maxUsedPercent": 50,
      "mode": "productivity",
      "guidance": "Optimize for output quality and momentum."
    },
    {
      "maxUsedPercent": 75,
      "mode": "balanced",
      "guidance": "Use standard models by default and move cleanup to cheaper models."
