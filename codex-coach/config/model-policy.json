    {
      "task": "debugging",
      "defaultModelClass": "standard",
      "escalateWhen": "Three repeated failed attempts or a production-impacting blocker."
    },
    {
      "task": "summarization",
      "defaultModelClass": "cheap",
      "escalateWhen": "Material business risk or dense technical ambiguity."
    },
    {
      "task": "agent development",
      "defaultModelClass": "standard",
      "escalateWhen": "Tool orchestration, approvals, or state management becomes unclear."
    }
  ]
